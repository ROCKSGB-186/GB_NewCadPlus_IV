        /// <summary>
        /// 浠庢湇鍔″櫒鑾峰彇棰勮鍥剧墖骞剁紦瀛?
        /// </summary>
        private async Task<BitmapImage> GetPreviewImageAsync(FileStorage fileStorage)
        {
            try
            {
                // 妫€鏌ユ枃浠跺瓨鍌ㄥ璞℃槸鍚︽湁鏁?
                if (fileStorage == null)
                {
                    LogManager.Instance.LogInfo("鏂囦欢瀛樺偍瀵硅薄涓虹┖");
                    return GetDefaultPreviewImage();
                }

                // 妫€鏌ュ唴瀛樼紦瀛?
                if (_imageCache.ContainsKey(fileStorage.FilePath ?? fileStorage.Id.ToString()))
                {
                    return _imageCache[fileStorage.FilePath ?? fileStorage.Id.ToString()];
                }

                // 妫€鏌ユ槸鍚︽湁棰勮鍥剧墖璺緞
                string previewImagePath = fileStorage.PreviewImagePath ?? fileStorage.FilePath;
                if (string.IsNullOrEmpty(previewImagePath))
                {
                    LogManager.Instance.LogInfo("棰勮鍥剧墖璺緞涓虹┖");
                    return GetDefaultPreviewImage();
                }

                // 妫€鏌ユ湰鍦扮紦瀛樻枃浠?
                string cacheFileName = $"{fileStorage.Id}_{Path.GetFileName(previewImagePath)}.png";
                string cacheFilePath = Path.Combine(_previewCachePath, cacheFileName);

                // 濡傛灉鏈湴缂撳瓨瀛樺湪涓旀湁鏁堬紝鐩存帴鍔犺浇
                if (File.Exists(cacheFilePath))
                {
                    try
                    {
                        var bitmap = LoadImageFromFile(cacheFilePath);
                        if (bitmap != null)
                        {
                            // 娣诲姞鍒板唴瀛樼紦瀛?
                            _imageCache[fileStorage.FilePath ?? fileStorage.Id.ToString()] = bitmap;
                            return bitmap;
                        }
                    }
                    catch (Exception ex)
                    {
                        LogManager.Instance.LogInfo($"浠庢湰鍦扮紦瀛樺姞杞藉浘鐗囧け璐? {ex.Message}");
                        // 鍒犻櫎鎹熷潖鐨勭紦瀛樻枃浠?
                        try { File.Delete(cacheFilePath); } catch { }
                    }
                }

                // 灏濊瘯浠庡師濮嬭矾寰勫姞杞藉浘鐗?
                if (File.Exists(previewImagePath))
                {
                    try
                    {
                        var bitmap = LoadImageFromFile(previewImagePath);
                        if (bitmap != null)
                        {
                            // 淇濆瓨鍒版湰鍦扮紦瀛?
                            try
                            {
                                using (var fileStream = File.Create(cacheFilePath))
                                {
                                    var encoder = new PngBitmapEncoder();
                                    encoder.Frames.Add(BitmapFrame.Create(bitmap));
                                    encoder.Save(fileStream);
                                }
                            }
                            catch (Exception cacheEx)
                            {
                                LogManager.Instance.LogInfo($"淇濆瓨鍒扮紦瀛樺け璐? {cacheEx.Message}");
                            }

                            // 娣诲姞鍒板唴瀛樼紦瀛?
                            _imageCache[fileStorage.FilePath ?? fileStorage.Id.ToString()] = bitmap;
                            return bitmap;
                        }
                    }
                    catch (Exception ex)
                    {
                        LogManager.Instance.LogInfo($"浠庡師濮嬭矾寰勫姞杞藉浘鐗囧け璐? {ex.Message}");
                    }
                }

                // 濡傛灉鎵€鏈夋柟娉曢兘澶辫触锛岃繑鍥為粯璁ゅ浘鐗?
                return GetDefaultPreviewImage();
            }
            catch (Exception ex)
            {
                LogManager.Instance.LogInfo($"鑾峰彇棰勮鍥剧墖鏃跺嚭閿? {ex.Message}");
                return GetDefaultPreviewImage();
            }
        }

        /// <summary>
        /// 浠庢枃浠跺姞杞藉浘鐗囷紙甯﹂敊璇鐞嗭級
        /// </summary>
        private BitmapImage LoadImageFromFile(string imagePath)
        {
            try
            {
                if (string.IsNullOrEmpty(imagePath) || !File.Exists(imagePath))
                    return null;

                // 鑾峰彇鏂囦欢鎵╁睍鍚?
                string extension = Path.GetExtension(imagePath)?.ToLower();

                // 鏍规嵁鏂囦欢绫诲瀷浣跨敤涓嶅悓鐨勫姞杞芥柟娉?
                switch (extension)
                {
                    case ".png":
                    case ".jpg":
                    case ".jpeg":
                    case ".bmp":
                    case ".gif":
                    case ".tif":
                    case ".tiff":
                        return LoadStandardImage(imagePath);
                    default:
                        // 灏濊瘯浣跨敤榛樿鏂瑰紡鍔犺浇
                        return LoadStandardImage(imagePath);
                }
            }
            catch (Exception ex)
            {
                LogManager.Instance.LogInfo($"鍔犺浇鍥剧墖鏂囦欢澶辫触 {imagePath}: {ex.Message}");
                return null;
            }
        }

        /// <summary>
        /// 鍔犺浇鏍囧噯鍥剧墖鏍煎紡
        /// </summary>
        private BitmapImage LoadStandardImage(string imagePath)
        {
            try
            {
                var bitmap = new BitmapImage();
                bitmap.BeginInit();
                bitmap.UriSource = new Uri(imagePath, UriKind.Absolute);
                bitmap.CacheOption = BitmapCacheOption.OnLoad;
                bitmap.CreateOptions = BitmapCreateOptions.IgnoreImageCache;
                bitmap.EndInit();
                bitmap.Freeze(); // 鍐荤粨浠ユ彁楂樻€ц兘
                return bitmap;
            }
            catch (Exception ex)
            {
                LogManager.Instance.LogInfo($"鍔犺浇鏍囧噯鍥剧墖澶辫触 {imagePath}: {ex.Message}");

                // 灏濊瘯浣跨敤娴佹柟寮忓姞杞?
                try
                {
                    using (var stream = new FileStream(imagePath, FileMode.Open, FileAccess.Read))
                    {
                        var bitmap = new BitmapImage();
                        bitmap.BeginInit();
                        bitmap.StreamSource = stream;
                        bitmap.CacheOption = BitmapCacheOption.OnLoad;
                        bitmap.EndInit();
                        bitmap.Freeze();
                        return bitmap;
                    }
                }
                catch (Exception streamEx)
                {
                    LogManager.Instance.LogInfo($"娴佹柟寮忓姞杞藉浘鐗囦篃澶辫触 {imagePath}: {streamEx.Message}");
                    return null;
                }
            }
        }

