        /// <summary>
        /// 瀵煎嚭DataTable鍒癊xcel
        /// </summary>
        public bool ExportDataTableToExcel(DataTable dataTable, string filePath)
        {
            try
            {
                // 浣跨敤EPPlus搴撳鍑篍xcel锛堟帹鑽愭柟寮忥級
                using (var package = new ExcelPackage())
                {
                    var worksheet = package.Workbook.Worksheets.Add("鍥惧厓鎵归噺娣诲姞妯℃澘");

                    // 娣诲姞鏍囬琛?
                    for (int i = 0; i < dataTable.Columns.Count; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = dataTable.Columns[i].ColumnName;
                        worksheet.Cells[1, i + 1].Style.Font.Bold = true;

                        // 淇ExcelFillPatternType鐨勫紩鐢ㄩ棶棰?
                        worksheet.Cells[1, i + 1].Style.Fill.PatternType = ExcelFillStyle.Solid;
                        worksheet.Cells[1, i + 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightBlue);
                    }

                    // 娣诲姞鏁版嵁琛?
                    for (int i = 0; i < dataTable.Rows.Count; i++)
                    {
                        for (int j = 0; j < dataTable.Columns.Count; j++)
                        {
                            worksheet.Cells[i + 2, j + 1].Value = dataTable.Rows[i][j];
                        }
                    }

                    // 鑷姩璋冩暣鍒楀
                    worksheet.Cells.AutoFitColumns();

                    // 淇濆瓨鏂囦欢
                    var fileInfo = new FileInfo(filePath);
                    package.SaveAs(fileInfo);
                }

                return true;
            }
            catch (Exception ex)
            {
                LogManager.Instance.LogError($"瀵煎嚭Excel鏃跺嚭閿? {ex.Message}");
                return false;
            }
        }

