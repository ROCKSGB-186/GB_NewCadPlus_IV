        /// <summary>
        /// 鑾峰彇鏈€缁堝姞杞界殑 CSV 鏂囦欢璺緞
        /// 浼樺厛绾э細澶栭儴闄勪欢鐩綍 > 绋嬪簭 Resources 鐩綍 > 寮€鍙戠洰褰?Resources
        /// </summary>
        private string ResolveCalcCsvPath(string fileName)
        {
            string externalPath = System.IO.Path.Combine(GetCalcCsvExternalDirectory(), fileName);

            // 1) 鏈湴宸叉湁锛岀洿鎺ョ敤鏈湴
            if (System.IO.File.Exists(externalPath))
                return externalPath;

            // 2) 杩愯鐩綍 Resources 浣滀负绉嶅瓙
            string runtimeResourcePath = System.IO.Path.Combine(
                AppDomain.CurrentDomain.BaseDirectory,
                "Resources",
                fileName);

            if (TrySeedCalcCsvToExternal(runtimeResourcePath, externalPath, out string resolvedFromRuntime))
                return resolvedFromRuntime;

            // 3) 寮€鍙戠洰褰?Resources 浣滀负绉嶅瓙锛堣皟璇曞厹搴曪級
            string devResourcePath = System.IO.Path.Combine(
                @"C:\Users\ShiGu\source\repos\GB_NewCadPlus_LM\Resources",
                fileName);

            if (TrySeedCalcCsvToExternal(devResourcePath, externalPath, out string resolvedFromDev))
                return resolvedFromDev;

            // 4) 鏈€鍚庡皾璇曚粠 Resources.resx 瀵煎嚭鍒版湰鍦板閮ㄧ洰褰?
            if (TryExportCalcCsvFromResx(fileName, externalPath, out string exportedPath))
                return exportedPath;

            // 鎵句笉鍒版椂杩斿洖鏈湴鐩爣璺緞锛屼究浜庢棩蹇楁彁绀?
            return externalPath;
        }
        /// <summary>
        /// 鐢ㄧ瀛愭枃浠跺垵濮嬪寲鏈湴澶栭儴 CSV銆?
        /// 鎴愬姛鏃朵紭鍏堣繑鍥炴湰鍦?externalPath锛涜嫢澶嶅埗澶辫触鍒欏洖閫€杩斿洖 seedPath锛堜繚璇佷粛鍙鍙栵級
        /// </summary>
        private bool TrySeedCalcCsvToExternal(string seedPath, string externalPath, out string resolvedPath)
        {
            resolvedPath = string.Empty;

            if (string.IsNullOrWhiteSpace(seedPath) || !System.IO.File.Exists(seedPath))
                return false;

            try
            {
                string? directory = System.IO.Path.GetDirectoryName(externalPath);
                if (!string.IsNullOrWhiteSpace(directory) && !System.IO.Directory.Exists(directory))
                {
                    System.IO.Directory.CreateDirectory(directory);
                }

                if (!System.IO.File.Exists(externalPath))
                {
                    System.IO.File.Copy(seedPath, externalPath, false);
                    LogManager.Instance.LogInfo($"宸茬敤绉嶅瓙鍏紡鏂囦欢鍒濆鍖栨湰鍦版ā鏉匡細{externalPath}");
                }

                resolvedPath = externalPath;
                return true;
            }
            catch (Exception ex)
            {
                LogManager.Instance.LogWarning($"绉嶅瓙鍏紡鏂囦欢澶嶅埗鍒版湰鍦板け璐ワ紝鏀逛负鐩存帴鍔犺浇绉嶅瓙鏂囦欢锛歿ex.Message}");
                resolvedPath = seedPath;
                return true;
            }
        }
        /// <summary>
        /// 灏濊瘯浠?Resources.resx 涓鍑?CSV 鍒板閮ㄩ檮浠剁洰褰?
        /// </summary>
        private bool TryExportCalcCsvFromResx(string fileName, string targetPath, out string exportedPath)
        {
            exportedPath = string.Empty;

            foreach (string resourceKey in GetCalcCsvResourceCandidateKeys(fileName))
            {
                try
                {
                    object? resourceObject = global::GB_NewCadPlus_LM.Resources.ResourceManager.GetObject(
                        resourceKey,
                        global::GB_NewCadPlus_LM.Resources.Culture);

                    if (!(resourceObject is byte[] bytes) || bytes.Length == 0)
                        continue;

                    string? directory = System.IO.Path.GetDirectoryName(targetPath);
                    if (!string.IsNullOrWhiteSpace(directory) && !System.IO.Directory.Exists(directory))
                    {
                        System.IO.Directory.CreateDirectory(directory);
                    }

                    System.IO.File.WriteAllBytes(targetPath, bytes);
                    exportedPath = targetPath;

                    LogManager.Instance.LogInfo(
                        $"宸蹭粠 Resources.resx 瀵煎嚭 CSV锛氳祫婧愰敭={resourceKey}锛岀洰鏍囨枃浠?{targetPath}");

                    return true;
                }
                catch (Exception ex)
                {
                    LogManager.Instance.LogWarning(
                        $"浠?Resources.resx 瀵煎嚭 CSV 澶辫触锛氳祫婧愰敭={resourceKey}锛岄敊璇?{ex.Message}");
                }
            }

            return false;
        }

        /// <summary>
        /// 鏍规嵁 CSV 鏂囦欢鍚嶇敓鎴愬彲鑳界殑 Resources.resx 璧勬簮閿?
        /// 鍏煎锛?
        /// 1. 鏂囦欢鍚嶅幓鎺?.csv 鍚庣洿鎺ュ尮閰?
        /// 2. 杩滃瀷 / 杩戝瀷 鍦?resx 涓杞垚 _杩淿鍨?/ _杩慱鍨?鐨勬儏鍐?
        /// 3. 涓嫳鏂囨嫭鍙疯杞垚涓嬪垝绾跨殑鎯呭喌
        /// </summary>
        private IEnumerable<string> GetCalcCsvResourceCandidateKeys(string fileName)
        {
            var keys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            void AddKey(string? key)
            {
                if (!string.IsNullOrWhiteSpace(key))
                    keys.Add(key.Trim());
            }

            string baseName = System.IO.Path.GetFileNameWithoutExtension(fileName).Trim();

            AddKey(baseName);
            AddKey(baseName.Replace("杩滃瀷", "_杩淿鍨?).Replace("杩戝瀷", "_杩慱鍨?));
            AddKey(baseName.Replace("(杩?", "_杩淿").Replace("(杩?", "_杩慱"));
            AddKey(baseName.Replace("锛堣繙锛?, "_杩淿").Replace("锛堣繎锛?, "_杩慱"));
            AddKey(
                baseName
                    .Replace("(杩?", "_杩淿")
                    .Replace("(杩?", "_杩慱")
                    .Replace("锛堣繙锛?, "_杩淿")
                    .Replace("锛堣繎锛?, "_杩慱")
                    .Replace("杩滃瀷", "_杩淿鍨?)
                    .Replace("杩戝瀷", "_杩慱鍨?));

            return keys;
        }

