        /// <summary>
        /// 浠庢暟鎹簱涓烘寚瀹氬垎绫诲姞杞芥寜閽?
        /// </summary>
        private async void LoadButtonsFromDatabaseForCategory(string categoryName, WrapPanel panel)
        {
            try
            {
                LogManager.Instance.LogInfo($"=== 寮€濮嬩粠鏁版嵁搴撳姞杞藉垎绫?{categoryName} ===");

                if (_databaseManager == null)
