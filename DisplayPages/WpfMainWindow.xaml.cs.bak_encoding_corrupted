        /// <summary>
        /// 浠?LoginWindow 璇诲彇鏈嶅姟鍣ㄩ厤缃?
        /// </summary>
        private void LoadServerConfigFromLogin()
        {
            try
            {
                // 浠庣櫥褰曠獥鍙ｄ腑璇诲彇鏈嶅姟鍣ㄩ厤缃?
                var configPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "GB_NewCadPlus_LM", "login_config.json");
                if (!File.Exists(configPath))// 濡傛灉鏂囦欢涓嶅瓨鍦紝鍒欒繑鍥?
                    return;

                var json = File.ReadAllText(configPath);//璇诲彇閰嶇疆鏂囦欢鍐呭
                var ser = new JavaScriptSerializer();//鍒涘缓JavaScript搴忓垪鍖栧櫒
                var dict = ser.Deserialize<Dictionary<string, object>>(json);//鍙嶅簭鍒楀寲JSON
                if (dict == null)
                    return;

                if (dict.TryGetValue("ServerIP", out var sip) && sip != null)// 灏濊瘯鑾峰彇 ServerIP
                {
                    // 灏嗙櫥褰曠獥鍙ｄ腑鐨勬湇鍔″櫒 IP 鍚屾鍥炶缃晫闈㈡枃鏈锛屼繚璇?UI 涓庡疄闄呬娇鐢ㄤ竴鑷?
                    TextBox_Set_ServiceIP.Text = sip.ToString();
                }

                if (dict.TryGetValue("ServerPort", out var sport) && sport != null)// 灏濊瘯鑾峰彇 ServerPort
                {
                    TextBox_Set_ServicePort.Text = sport.ToString();//鍚屾鍥炶缃晫闈㈡枃鏈
                }
            }
            catch (Exception ex)
            {
                LogManager.Instance.LogInfo($"鍔犺浇鐧诲綍绐楀彛閰嶇疆澶辫触: {ex.Message}");
                LogManager.Instance.LogInfo($"鍔犺浇鐧诲綍绐楀彛閰嶇疆澶辫触: {ex.Message}");
                // 涓嶈鎶涘紓甯革紝澶辫触鍒欑户缁娇鐢ㄧ晫闈腑宸叉湁鐨勫€?
            }
        }

