                                double sizeZ = Math.Abs((double)ext.MaxPoint.Z - (double)ext.MinPoint.Z);
                                if (sizeX <= 0.0) continue;

                                double sizeY_m = sizeY / unitToMeters;
                                double sizeZ_m = sizeZ / unitToMeters;
                                int roundedY = (int)Math.Round(sizeY_m * 1000.0);
