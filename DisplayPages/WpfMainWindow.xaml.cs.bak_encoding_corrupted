                // 褰撳墠鐢ㄦ埛鍚嶏紙鍙兘涓虹┖锛?
                string username = VariableDictionary._userName ?? string.Empty;

                // 2) 涓汉瀛楀吀锛堣鐩栨爣鍑嗗瓧鍏革級
                try
