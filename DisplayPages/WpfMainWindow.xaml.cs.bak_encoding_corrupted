        private void SaveSettings()
        {
            try
            {
                // 鏇存柊瀛楁鍊?
                VariableDictionary._serverIP = TextBox_Set_ServiceIP.Text.Trim();
                VariableDictionary._serverPort = int.TryParse(TextBox_Set_ServicePort.Text.Trim(), out int port) ? port : 3306;
