                    {
                        AllowNone = true,
                        DefaultValue = unitToMeters,
                        UseDefaultValue = true,
                        AllowZero = false,
                        AllowNegative = false
                    };
                    var pdr = ed.GetDouble(pdo);
                    if (pdr.Status == Autodesk.AutoCAD.EditorInput.PromptStatus.OK && pdr.Value > 0.0)
