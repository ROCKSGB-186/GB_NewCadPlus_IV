                    // 娉ㄦ剰锛氳繖閲屼笉瑕佷娇鐢?ConfigureAwait(false)锛岄渶瑕佷繚鎸佸紓甯镐笌涓婁笅鏂囩殑鑷劧浼犳挱涓庤褰曘€?
                    var personal = await _databaseManager.GetLayerDictionaryByUsernameAsync(username);
