        /// 浠呭綋鐢ㄦ埛鍚嶄负 "sa" 鎴?"admin"锛堜笉鍖哄垎澶у皬鍐欙級鏃舵墠鏄剧ず锛涘惁鍒欐姌鍙狅紙Collapsed锛?
        ///</summary>
        private void UpdateAdminTabsVisibility()
        {
            try
            {
                // 鑾峰彇褰撳墠鐢ㄦ埛鍚嶏紙浼樺厛浣跨敤鍏ㄥ眬鍙橀噺锛屽啀閫€鍥炲埌璁剧疆鐣岄潰杈撳叆锛?
                var userName = (VariableDictionary._userName ?? TextBox_Set_Username.Text ?? string.Empty).Trim().ToLowerInvariant();
                bool isAdmin = userName == "sa" || userName == "admin" || userName == "root";

                if (MainTabControl == null)
                {
                    LogManager.Instance.LogInfo("UpdateAdminTabsVisibility: MainTabControl 涓?null锛岃烦杩?);
                    return;
                }
                if (!isAdmin)
                    // 閬嶅巻 TabControl 鐨?TabItem锛屾牴鎹?Header 鏂囨湰鍒ゆ柇骞惰缃?Visibility
                    foreach (var item in MainTabControl.Items)
                    {
                        if (item is TabItem tab)
                        {
                            string header = tab.Header?.ToString() ?? string.Empty;

                            // 鍖归厤鍖呭惈鈥滅鐞嗗憳鈥濆叧閿瘝鐨?TabItem
                            if (header.IndexOf("绠＄悊鍛?, StringComparison.OrdinalIgnoreCase) >= 0)
                            {
                                tab.Visibility = System.Windows.Visibility.Collapsed;
                                continue;
                            }

                            // 鍖归厤鈥滈儴闂ㄢ€濇垨鈥滀汉鍛樷€濆叧閿瘝锛堝父瑙佺粍鍚堜负 鈥滈儴闂?浜哄憳鈥濄€佲€滈儴闂╘浜哄憳鈥?绛夛級
                            if (header.IndexOf("閮ㄩ棬", StringComparison.OrdinalIgnoreCase) >= 0 ||
                                header.IndexOf("浜哄憳", StringComparison.OrdinalIgnoreCase) >= 0)
                            {
                                // 杩涗竴姝ラ伩鍏嶈浼わ紙渚嬪 鈥滀汉鍛樺垪琛ㄢ€?涔熺畻浜哄憳妯″潡锛?
                                // 杩欓噷鎸夐渶姹傜粺涓€鎺у埗锛氬彧瑕佸寘鍚儴闂ㄦ垨浜哄憳灏卞彈鏉冮檺鎺у埗
                                tab.Visibility = System.Windows.Visibility.Collapsed;
                            }
