        /// <summary>
        /// 鎻愬彇瀛楃涓蹭腑鐨勪腑鏂囧瓧绗︼紝鍘婚櫎鎵€鏈夌鍙蜂笌鑻辨枃瀛楁瘝
        /// </summary>
        /// <param Name="input">杈撳叆瀛楃涓?/param>
        /// <returns>鍙寘鍚腑鏂囧瓧绗︾殑瀛楃涓?/returns>
        private string ExtractChineseCharacters(string input)
        {
            //浣跨敤姝ｅ垯琛ㄨ揪寮?鎻愬彇涓枃瀛楃
            if (string.IsNullOrWhiteSpace(input)) return string.Empty;
            //鍖归厤涓枃瀛楃 姝ｅ垯琛ㄨ揪寮忓尮閰嶄腑鏂囧瓧绗﹁寖鍥?
            var matches = Regex.Matches(input!, @"[\u4e00-\u9fff]+");
            //鑾峰彇鍖归厤鐨勫瓧绗︿覆濡傛灉娌℃湁鍖归厤鍒颁腑鏂囧瓧绗︼紝杩斿洖绌哄瓧绗︿覆
            if (matches.Count == 0) return string.Empty;
            //鑾峰彇鍖归厤鐨勫瓧绗︿覆骞舵嫾鎺ヤ负涓€涓瓧绗︿覆杩炴帴鎵€鏈夊尮閰嶅埌鐨勪腑鏂囧瓧绗?
            return string.Concat(matches.Cast<Match>().Select(m => m.Value)).Trim();
        }

