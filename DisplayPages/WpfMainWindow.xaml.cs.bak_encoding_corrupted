            public LayerManager()
            {
                _layerInfo = new List<LayerInfo>();
                _workingDirectory = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData),
                                               "GB_NewCadPlus_LM");
                if (!Directory.Exists(_workingDirectory))
