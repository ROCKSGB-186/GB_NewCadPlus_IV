        /// <summary>
        /// 鏌ユ壘鍙鍖栨爲涓殑瀛愬厓绱?
        /// </summary>
        /// <typeparam Name="T">瑕佹煡鎵剧殑鍏冪礌绫诲瀷</typeparam>
        /// <param Name="parent">鐖跺厓绱?/param>
        /// <param Name="childName">瀛愬厓绱犲悕绉?/param>
        /// <returns>鎵惧埌鐨勫瓙鍏冪礌鎴杗ull</returns>
        private T FindVisualChild<T>(DependencyObject parent, string childName) where T : DependencyObject
        {
            // 閬嶅巻鎵€鏈夊瓙鍏冪礌
            for (int i = 0; i < VisualTreeHelper.GetChildrenCount(parent); i++)
            {
                var child = VisualTreeHelper.GetChild(parent, i);

                // 妫€鏌ユ槸鍚︽槸鐩爣绫诲瀷
                if (child != null && child is T typedChild)
                {
                    // 妫€鏌ュ悕绉版槸鍚﹀尮閰?
                    if (child is FrameworkElement frameworkElement && frameworkElement.Name == childName)
                    {
                        return typedChild;
                    }
                }

                // 閫掑綊鏌ユ壘瀛愬厓绱?
                var childOfChild = FindVisualChild<T>(child, childName);
                if (childOfChild != null)
                {
                    return childOfChild;
                }
            }

            return null;
        }

