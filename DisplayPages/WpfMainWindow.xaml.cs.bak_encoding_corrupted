        /// <summary>
        /// 鏂板锛氫负鍔ㄦ€佹寜閽粺涓€闄勫姞榧犳爣浜嬩欢鍜?click 澶勭悊鍣紝閬垮厤閲嶅缁戝畾棰勫畾涔夋寜閽?
        /// </summary>
        private static readonly DependencyProperty HandlersAttachedProperty = DependencyProperty.RegisterAttached("HandlersAttached", typeof(bool), typeof(WpfMainWindow), new PropertyMetadata(false));

        /// <summary>
        /// 涓哄姩鎬佹寜閽檮鍔犻紶鏍囦簨浠跺拰 click 澶勭悊鍣?
        /// </summary>
        /// <param name="btn"></param>
        private void AttachDynamicButtonHandlers(Button btn)
        {
            if (btn == null) return;

            bool attached = false;
            try
            {
                attached = (bool)btn.GetValue(HandlersAttachedProperty);
            }
            catch { attached = false; }

            if (attached) return;

            // 濡傛灉璇ユ寜閽槸棰勫畾涔夋寜閽紙Type=="Predefined"锛夛紝涓嶈鏇挎崲瀹冨凡鏈夌殑 Click 澶勭悊鍣?
            var tagInfo = btn.Tag as ButtonTagCommandInfo;
            bool isPredefined = tagInfo != null && string.Equals(tagInfo.Type, "Predefined", StringComparison.OrdinalIgnoreCase);

            // 鍙湁闈為瀹氫箟鎸夐挳鎵嶇粦瀹?DynamicButton_Click锛堣祫婧愭ā寮忓緢澶氭寜閽渶鍒濇病缁戝畾锛?
            if (!isPredefined)
            {
                // 浠呭湪灏氭湭缁戝畾鏃堕檮鍔?Click锛堜繚瀹堢瓥鐣ワ級
                btn.Click += DynamicButton_Click;
                // 榛樿鎶婂姩鎬佺敓鎴愮殑鎸夐挳鑳屾櫙璁剧疆涓?Azure锛堜粎鍦ㄦ病鏈夋樉寮忚儗鏅椂锛?
                try
                {
                    var current = btn.Background;
                    bool isTransparentOrNull =
                        current == null ||
                        (current is System.Windows.Media.SolidColorBrush scb && scb.Color == System.Windows.Media.Colors.Transparent);

                    if (isTransparentOrNull)
                    {
                        btn.Background = System.Windows.Media.Brushes.Azure;
                    }
                    btn.Background = System.Windows.Media.Brushes.Azure;
                }
                catch
                {
                    // 蹇界暐浠讳綍璁剧疆鑳屾櫙鏃剁殑寮傚父锛屼笉涓柇娴佺▼
                }
            }

            // 濮嬬粓缁戝畾棰勬榧犳爣浜嬩欢浠ユ敮鎸佸弻鍑讳笌鎷栨嫿
            btn.PreviewMouseLeftButtonDown += DynamicButton_PreviewMouseLeftButtonDown;
            btn.PreviewMouseMove += DynamicButton_PreviewMouseMove;
            btn.PreviewMouseLeftButtonUp += DynamicButton_PreviewMouseLeftButtonUp;
            btn.SetValue(HandlersAttachedProperty, true);
        }

        /// <summary>
        /// 缁熶竴鍐欏叆鏂囦欢淇℃伅闈㈡澘锛堥伩鍏嶉噸澶嶄唬鐮侊級
        /// </summary>
        private void UpdateFileInfoPanel(
            string? filePath,
            string? displayName,
            string? fileType,
            long? fileSizeBytes,
            string? previewPath,
            bool formatDisplayName)
        {
            file_Path.Text = filePath ?? string.Empty;

            var finalName = displayName ?? string.Empty;
            if (formatDisplayName && !string.IsNullOrWhiteSpace(finalName))
            {
                finalName = FormatFileNameForDisplay(finalName);
            }
            File_Name.Text = finalName;

            File_Size.Text = (fileSizeBytes.HasValue && fileSizeBytes.Value > 0)
                ? $"{fileSizeBytes.Value / 1024.0:F2} KB"
                : string.Empty;

            File_Type.Text = fileType ?? string.Empty;
            if (string.IsNullOrWhiteSpace(File_Type.Text) && !string.IsNullOrWhiteSpace(filePath))
            {
                File_Type.Text = Path.GetExtension(filePath).ToLowerInvariant();
            }

            view_File_Path.Text = string.IsNullOrWhiteSpace(previewPath) ? "鏃犻瑙堝浘鐗? : previewPath;
        }

        /// <summary>
        /// 鏄剧ず鏂囦欢淇℃伅锛堣矾寰勬ā寮忥級
        /// </summary>
        private void DisplayFileInfo(string filePath)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(filePath))
                {
                    UpdateFileInfoPanel(string.Empty, string.Empty, string.Empty, null, string.Empty, false);
                    return;
                }

                var fileInfo = new FileInfo(filePath);
                UpdateFileInfoPanel(
                    filePath: filePath,
                    displayName: fileInfo.Name,
                    fileType: fileInfo.Extension.ToLowerInvariant(),
                    fileSizeBytes: fileInfo.Exists ? fileInfo.Length : null,
                    previewPath: view_File_Path.Text,
                    formatDisplayName: false);
            }
