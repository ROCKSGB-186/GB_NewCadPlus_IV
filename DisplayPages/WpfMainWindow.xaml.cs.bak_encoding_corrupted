        /// <summary>
        /// 缂栬緫缁撴潫鍚庢墽琛屽叏灞€鑱斿姩閲嶇畻
        /// </summary>
        private void DataGrid_璁＄畻琛ㄨ嚜鍔ㄨ仈鍔ㄩ噸绠梍CellEditEnding(object sender, DataGridCellEditEndingEventArgs e)
        {
            if (!(e.Row.Item is CalcCsvTableRow row))
                return;

            if (!row.IsEditable)
                return;

            Dispatcher.BeginInvoke(new Action(() =>
            {
                // 1) 涓嬫媺绫诲瀷涓嶅仛鏁板瓧鏍￠獙锛岀洿鎺ラ噸绠?
                if (row.IsMultiSelect)
                {
                    RecalculateAllCalcCsvTables();
                    return;
                }

                // 2) TemplateColumn 鍦烘櫙涓嬶紝浠ョ粦瀹氬悗鐨?ValueText 涓哄噯
                string committedText = (row.ValueText ?? string.Empty).Trim();
                string oldText = (_calcCsvEditingOldValue ?? string.Empty).Trim();

                // 3) 鏈敼鍊硷細涓嶆彁绀猴紝鐩存帴閫€鍑猴紙閬垮厤鈥滄病杈撳叆涔熸姤閿欌€濓級
                if (string.Equals(committedText, oldText, StringComparison.Ordinal))
                    return;

                // 4) 鍏佽绌鸿緭鍏ュ洖閫€鏃у€硷紝涓嶅脊閿欒
                if (string.IsNullOrWhiteSpace(committedText))
                {
                    row.ValueText = _calcCsvEditingOldValue;
                    return;
                }

                // 5) Input 绫诲瀷蹇呴』鏄暟瀛?
                if (!TryParseCalcCsvDouble(committedText, out double parsedValue))
                {
                    row.ValueText = _calcCsvEditingOldValue;
                    MessageBox.Show(
                        $"鍙傛暟鈥渰row.ParameterName}鈥濊杈撳叆鏈夋晥鏁板瓧銆?,
                        "鎻愮ず",
                        MessageBoxButton.OK,
                        MessageBoxImage.Warning);
                    return;
                }

                row.ValueText = FormatCalcCsvNumber(parsedValue);
                try
                {
                    RecalculateAllCalcCsvTables();
                }
                catch (Exception ex)
                {
                    LogManager.Instance.LogWarning($"鑱斿姩閲嶇畻澶辫触: {ex.Message}");
                    MessageBox.Show($"鑱斿姩閲嶇畻澶辫触锛歿ex.Message}", "鎻愮ず", MessageBoxButton.OK, MessageBoxImage.Warning);
                }
            }), System.Windows.Threading.DispatcherPriority.Background);
        }

