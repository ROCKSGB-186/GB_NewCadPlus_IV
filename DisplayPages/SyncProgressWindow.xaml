<Window x:Class="GB_NewCadPlus_IV.SyncProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GB_NewCadPlus_IV"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="正在复制文件"
        Width="620"
        Height="390"
        Background="#FFF3F3F3"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        mc:Ignorable="d">
    <Border Padding="18,16,18,16"
            Background="White"
            BorderBrush="#FFD9D9D9"
            BorderThickness="1"
            CornerRadius="4">
        <local:SyncProgressView x:Name="SyncProgressView" />
    </Border>
</Window>
