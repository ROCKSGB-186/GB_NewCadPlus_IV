<UserControl x:Class="GB_NewCadPlus_IV.SyncProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             DataContext="{Binding RelativeSource={RelativeSource Self}}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TitleTextBrush" Color="#FF1F1F1F" />
        <SolidColorBrush x:Key="BodyTextBrush" Color="#FF2D2D2D" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FF666666" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#FF6F6F6F" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFAFAFA" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FFE1E1E1" />
        <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#FFE9E9E9" />
        <SolidColorBrush x:Key="ProgressBarForegroundBrush" Color="#FF3A954B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF2B78D6" />

        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="18,4,18,4" />
            <Setter Property="Background" Value="#FFF2F2F2" />
            <Setter Property="BorderBrush" Value="#FFC8C8C8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Ellipse Width="12"
                     Height="12"
                     Margin="0,4,10,0"
                     Fill="{DynamicResource AccentBrush}" />

            <StackPanel Grid.Column="1" Orientation="Vertical">
                <TextBlock FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleTextBrush}"
                           Text="{Binding WindowTitle}" />
                <TextBlock Margin="0,2,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="{Binding StatusLine}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1"
                   Margin="0,2,0,4"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextBrush}"
                   Text="{Binding StageText}" />

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="{Binding CurrentItemText}" />

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar Height="22"
                         Margin="0,0,10,0"
                         Background="{DynamicResource ProgressBarBackgroundBrush}"
                         Foreground="{DynamicResource ProgressBarForegroundBrush}"
                         Maximum="100"
                         Minimum="0"
                         IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Value="{Binding ProgressValue}" />

            <TextBlock Grid.Column="1"
                       Style="{StaticResource ValueTextBlockStyle}"
                       VerticalAlignment="Center"
                       Text="{Binding ProgressValueText}" />
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                       Text="已复制：" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource ValueTextBlockStyle}"
                       Text="{Binding CopyCountText}" />
        </Grid>

        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                       Text="剩余时间：" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource ValueTextBlockStyle}"
                       Text="{Binding RemainingTimeText}" />

            <Expander Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Margin="0,10,0,0"
                      Header="详细信息"
                      IsExpanded="{Binding IsDetailsExpanded, Mode=TwoWay}">
                <Border Padding="10"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3">
                    <TextBox Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Segoe UI"
                             FontSize="12"
                             Foreground="#FF444444"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             Text="{Binding DetailsText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </Expander>
        </Grid>

        <StackPanel Grid.Row="6"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button x:Name="CancelButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="{Binding CancelButtonText}"
                    IsEnabled="{Binding IsCancelButtonEnabled}"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
